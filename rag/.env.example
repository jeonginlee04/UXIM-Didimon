# Supabase — Project Settings > API 에서 확인
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # embed.py 전용: service_role 키
SUPABASE_KEY=eyJ...          # server/index.js 전용: anon 키 (읽기 전용)

# OpenAI — platform.openai.com/api-keys
# embed.py(문서 임베딩) + server/index.js(질문 임베딩) 공용
OPENAI_API_KEY=sk-...

# Anthropic — console.anthropic.com/settings/keys
# server/index.js AI 채팅 엔드포인트 전용
ANTHROPIC_API_KEY=sk-ant-...
